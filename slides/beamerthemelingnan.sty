% A modern Lingnan-inspired Beamer theme for course and research presentations.
% Usage: \usetheme{lingnan}
\ProvidesPackage{beamerthemelingnan}[2026/05/07 Modern Lingnan Beamer theme]

\mode<presentation>

% Core packages
\RequirePackage[british]{babel}
\RequirePackage{fontspec}
\RequirePackage{xeCJK}
\RequirePackage{amsmath}
\RequirePackage{cancel}
\RequirePackage[normalem]{ulem}
\RequirePackage{unicode-math}
\RequirePackage{graphicx}
\RequirePackage{tikz}
\usetikzlibrary{positioning,arrows.meta}
\RequirePackage{booktabs}
\RequirePackage{array}
\RequirePackage{longtable}
\RequirePackage{multicol}
\RequirePackage{multirow}
\RequirePackage{color}
\RequirePackage{etoolbox}

\hypersetup{urlcolor=blue}
\useoutertheme[subsection=false]{miniframes}
\useinnertheme{circles}
\usecolortheme{beaver}
\usefonttheme{serif}

% Colors
\definecolor{lingnanred}{RGB}{223,0,69}
\definecolor{lingnangrey}{RGB}{213,213,210}
\definecolor{ModernRed}{RGB}{124,25,35}
\definecolor{ModernGold}{RGB}{191,139,61}
\definecolor{ModernGreen}{RGB}{62,112,92}
\definecolor{ModernInk}{RGB}{38,38,38}
\definecolor{ModernMist}{RGB}{247,244,239}
\definecolor{ModernSoftRed}{RGB}{250,238,238}
\definecolor{ModernSoftGreen}{RGB}{238,247,243}
\definecolor{NavBlueGrey}{RGB}{107,126,134}
\definecolor{NavDotGrey}{RGB}{132,139,141}

% Backward-compatible aliases used by older slides based on this template.
\colorlet{ClanRed}{ModernRed}
\colorlet{ClanGold}{ModernGold}
\colorlet{ClanGreen}{ModernGreen}
\colorlet{ClanInk}{ModernInk}
\colorlet{ClanMist}{ModernMist}
\colorlet{ClanSoftRed}{ModernSoftRed}
\colorlet{ClanSoftGreen}{ModernSoftGreen}

\setbeamercolor{section in head/foot}{bg=ModernSoftRed!55!white,fg=ModernRed}
\setbeamercolor{section in head/foot shaded}{bg=ModernSoftRed!55!white,fg=NavBlueGrey}
\setbeamercolor{author in head/foot}{parent=palette tertiary}
\setbeamercolor{title in head/foot}{bg=lingnangrey!50!white,fg=black}
\setbeamercolor{date in head/foot}{bg=lingnangrey!50!white,fg=black}
\setbeamercolor{page number in head/foot}{bg=lingnangrey!50!white,fg=black}
\setbeamercolor{logo in foot}{bg=lingnangrey!35!white}
\setbeamercolor{frametitle}{fg=ModernInk,bg=white}
\setbeamercolor{title}{fg=ModernRed}
\setbeamercolor{subtitle}{fg=ModernRed}
\setbeamercolor{normal text}{fg=ModernInk,bg=white}
\setbeamercolor{block title}{fg=white,bg=ModernRed}
\setbeamercolor{block body}{fg=ModernInk,bg=ModernMist}
\setbeamercolor{itemize item}{fg=ModernRed}
\setbeamercolor{itemize subitem}{fg=ModernRed}
\setbeamercolor{item}{fg=ModernRed}
\setbeamercolor{item projected}{fg=white,bg=ModernRed}
\setbeamercolor{qed symbol}{fg=ModernRed}
\setbeamercolor{caption name}{fg=ModernRed}
\setbeamercolor{button}{bg=ModernRed}
\setbeamercolor{bibliography entry author}{fg=ModernRed}
\setbeamercolor{bibliography entry note}{fg=ModernInk}
\setbeamercolor{h1}{bg=ModernRed}
\setbeamercolor{h2}{bg=lingnangrey!50!white}
\setbeamercolor{upper separation line head}{bg=ModernRed}
\setbeamercolor{lower separation line head}{bg=ModernRed}
\setbeamercolor{mini frame}{fg=NavDotGrey,bg=white}
\setbeamercolor{mini frame in current subsection}{fg=ModernRed,bg=ModernRed}
\setbeamercolor{mini frame in other subsection}{fg=NavDotGrey,bg=white}

% Font setup. The deck is Chinese-first, with English terminology kept readable.
\IfFontExistsTF{Times New Roman}{
  \setmainfont{Times New Roman}
}{
  \setmainfont{TeX Gyre Termes}
}

\IfFontExistsTF{Times New Roman}{
  \setsansfont{Times New Roman}
}{
  \IfFontExistsTF{TeX Gyre Termes}{
    \setsansfont{TeX Gyre Termes}
  }{
    \IfFontExistsTF{TeX Gyre Heros}{
      \setsansfont{TeX Gyre Heros}
    }{
      \IfFontExistsTF{Arial}{
        \setsansfont{Arial}
      }{
        \setsansfont{texgyretermes-regular.otf}[
          BoldFont=texgyretermes-bold.otf,
          ItalicFont=texgyretermes-italic.otf,
          BoldItalicFont=texgyretermes-bolditalic.otf
        ]
      }
    }
  }
}

\IfFontExistsTF{Times New Roman}{
  \newfontfamily\lingnanheadinglatinfont{Times New Roman}
}{
  \IfFontExistsTF{TeX Gyre Termes}{
    \newfontfamily\lingnanheadinglatinfont{TeX Gyre Termes}
  }{
    \IfFontExistsTF{Cambria}{
      \newfontfamily\lingnanheadinglatinfont{Cambria}
    }{
      \IfFontExistsTF{TeX Gyre Heros}{
        \newfontfamily\lingnanheadinglatinfont{TeX Gyre Heros}
      }{
        \newfontfamily\lingnanheadinglatinfont{texgyretermes-regular.otf}[
          BoldFont=texgyretermes-bold.otf,
          ItalicFont=texgyretermes-italic.otf,
          BoldItalicFont=texgyretermes-bolditalic.otf
        ]
      }
    }
  }
}
\DeclareRobustCommand{\latinheading}[1]{\texorpdfstring{{\lingnanheadinglatinfont #1}}{#1}}

\IfFontExistsTF{Cascadia Code}{
  \setmonofont{Cascadia Code}
}{
  \IfFontExistsTF{Menlo}{
    \setmonofont{Menlo}
  }{
    \IfFontExistsTF{Monaco}{
      \setmonofont{Monaco}
    }{
      \IfFontExistsTF{Consolas}{
        \setmonofont{Consolas}
      }{
        \setmonofont{Latin Modern Mono}
      }
    }
  }
}

\IfFontExistsTF{TeX Gyre Termes Math}{
  \setmathfont{TeX Gyre Termes Math}
}{
  \setmathfont{texgyretermes-math.otf}
}

\IfFontExistsTF{Songti SC}{
  \setCJKmainfont{Songti SC}[AutoFakeBold=2.0]
}{
  \IfFontExistsTF{Source Han Serif SC}{
    \setCJKmainfont{Source Han Serif SC}[AutoFakeBold=2.0]
  }{
    \IfFontExistsTF{Noto Serif CJK SC}{
      \setCJKmainfont{Noto Serif CJK SC}[AutoFakeBold=2.0]
    }{
      \IfFontExistsTF{STZhongsong}{
        \setCJKmainfont{STZhongsong}[AutoFakeBold=2.0]
      }{
        \IfFontExistsTF{PingFang SC}{
          \setCJKmainfont{PingFang SC}[AutoFakeBold=2.0]
        }{
          \IfFontExistsTF{KaiTi}{
            \setCJKmainfont{KaiTi}[AutoFakeBold=2.0]
          }{
            \IfFontExistsTF{STKaiti}{
              \setCJKmainfont{STKaiti}[AutoFakeBold=2.0]
            }{
              \IfFontExistsTF{Microsoft YaHei}{
                \setCJKmainfont{Microsoft YaHei}
              }{
                \setCJKmainfont{FandolSong-Regular.otf}
              }
            }
          }
        }
      }
    }
  }
}

\IfFontExistsTF{Songti SC}{
  \setCJKsansfont{Songti SC}[AutoFakeBold=2.0]
}{
  \IfFontExistsTF{Source Han Serif SC}{
    \setCJKsansfont{Source Han Serif SC}[AutoFakeBold=2.0]
  }{
    \IfFontExistsTF{Noto Serif CJK SC}{
      \setCJKsansfont{Noto Serif CJK SC}[AutoFakeBold=2.0]
    }{
      \IfFontExistsTF{STZhongsong}{
        \setCJKsansfont{STZhongsong}[AutoFakeBold=2.0]
      }{
        \IfFontExistsTF{PingFang SC}{
          \setCJKsansfont{PingFang SC}[AutoFakeBold=2.0]
        }{
          \IfFontExistsTF{Microsoft YaHei}{
            \setCJKsansfont{Microsoft YaHei}
          }{
            \setCJKsansfont{FandolHei-Regular.otf}
          }
        }
      }
    }
  }
}

\IfFontExistsTF{PingFang SC}{
  \setCJKmonofont{PingFang SC}
}{
  \IfFontExistsTF{Microsoft YaHei}{
    \setCJKmonofont{Microsoft YaHei}
  }{
    \setCJKmonofont{FandolHei-Regular.otf}
  }
}

\IfFontExistsTF{PingFang SC}{
  \setCJKfallbackfamilyfont{\CJKsfdefault}{PingFang SC}
}{
  \IfFontExistsTF{Microsoft YaHei}{
    \setCJKfallbackfamilyfont{\CJKsfdefault}{Microsoft YaHei}
  }{}
}
\xeCJKsetup{AutoFallBack=true}

% Basic Beamer style
\setbeamerfont{title}{family=\lingnanheadinglatinfont,series=\bfseries,size=\Large}
\setbeamerfont{frametitle}{family=\sffamily,series=\bfseries,size=\large}
\setbeamerfont{section title}{family=\sffamily}
\setbeamerfont{section in head/foot}{family=\lingnanheadinglatinfont,series=\bfseries,size=\tiny}
\setbeamerfont{date}{size=\footnotesize}
\setbeamerfont{normal text}{size=\small}
\setbeamerfont{block title}{family=\sffamily,size=\normalsize}
\setbeamerfont{block body}{size=\small}
\setcounter{tocdepth}{1}
\setbeamertemplate{caption}[numbered]
\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{section in toc}[square]
\setbeamertemplate{enumerate items}[default]
\setbeamertemplate{blocks}[rounded]
\setbeamertemplate{bibliography item}{\insertbiblabel}
\setbeamertemplate{itemize item}{\raise0.18ex\hbox{\tiny$\blacktriangleright$}}
\setbeamertemplate{itemize subitem}{\raise0.08ex\hbox{\normalsize$\bullet$}}
\setbeamercovered{dynamic}
\setlength{\leftmargini}{1.2em}
\newcommand{\lingnannavitem}[3]{%
  \ifnum\thesection=#1
    \hyperlink{Navigation#3}{%
      \begin{beamercolorbox}[wd=0.2\paperwidth,ht=3.2ex,dp=1.05ex,center]{section in head/foot}
        \usebeamerfont{section in head/foot}#2
      \end{beamercolorbox}%
    }%
  \else
    \hyperlink{Navigation#3}{%
      \begin{beamercolorbox}[wd=0.2\paperwidth,ht=3.2ex,dp=1.05ex,center]{section in head/foot shaded}
        \usebeamerfont{section in head/foot}#2
      \end{beamercolorbox}%
    }%
  \fi
}

\newcommand{\lingnansectionnav}{%
  \hbox to \paperwidth{%
    \lingnannavitem{1}{Introduction}{3}%
    \lingnannavitem{2}{Literature Gap and Question}{4}%
    \lingnannavitem{3}{Method}{5}%
    \lingnannavitem{4}{Results and Discussion}{6}%
    \lingnannavitem{5}{Conclusion}{8}%
  }%
}

% Title-page metadata helpers
\providecommand{\inserttitlepageinfo}{}
\newcommand{\titlepageinfo}[1]{\renewcommand{\inserttitlepageinfo}{#1}}
\providecommand{\inserttitlepagefooter}{}
\newcommand{\titlepagefooter}[1]{\renewcommand{\inserttitlepagefooter}{#1}}

% Convenience commands for short presentation slides.
\newcommand{\slidetag}[1]{%
  {\sffamily\bfseries\scriptsize\color{ModernRed}#1}\vspace{0.25em}}

\newcommand{\keymessage}[2]{%
  \par\vskip\medskipamount%
  \begin{beamercolorbox}[wd=\textwidth,sep=0.20cm,rounded=true]{block body}
    {\sffamily\bfseries\color{ModernRed}#1}\quad #2
  \end{beamercolorbox}}

\newcommand{\focus}[1]{{\sffamily\bfseries\color{ModernRed}#1}}
\newcommand{\mathhighlight}[1]{\textcolor{ModernRed}{#1}}
\newcommand{\hcancel}[1]{\text{\sout{\ensuremath{#1}}}}

\newcommand{\datapill}[2]{%
  \begin{beamercolorbox}[wd=\linewidth,sep=0.16cm,rounded=true]{block body}
    {\sffamily\bfseries\color{ModernRed}#1}\par
    {\footnotesize #2}
  \end{beamercolorbox}}

% Header and footer
\setbeamertemplate{headline}{%
  \ifnum\insertframenumber>1
    \begin{beamercolorbox}{section in head/foot}
      \vskip2.4ex
      \vskip-\baselineskip
      \hspace*{0.2cm}\insertnavigation{\dimexpr\paperwidth-0.4cm\relax}
      \vskip1.0ex
    \end{beamercolorbox}%
  \fi
}

\setbeamertemplate{footline}
{
  \leavevmode
  \vbox{%
    \begin{beamercolorbox}[wd=\paperwidth,ht=0.62cm,dp=0.06cm,left]{logo in foot}
      \hspace*{0.55cm}\raisebox{0.08cm}{\includegraphics[height=0.46cm]{image/logo.png}}
    \end{beamercolorbox}%
    \hbox{%
      \begin{beamercolorbox}[wd=.22\paperwidth,ht=2.25ex,dp=1ex,center]{author in head/foot}
        \usebeamerfont{author in head/foot}\insertshortauthor
      \end{beamercolorbox}%
      \begin{beamercolorbox}[wd=.46\paperwidth,ht=2.25ex,dp=1ex,center]{title in head/foot}
        \usebeamerfont{title in head/foot}\insertshorttitle
      \end{beamercolorbox}%
      \begin{beamercolorbox}[wd=.20\paperwidth,ht=2.25ex,dp=1ex,center]{date in head/foot}
        \usebeamerfont{date in head/foot}\insertshortdate
      \end{beamercolorbox}%
      \begin{beamercolorbox}[wd=.12\paperwidth,ht=2.25ex,dp=1ex,right]{page number in head/foot}
        \usebeamerfont{page number in head/foot}\insertframenumber{} / \inserttotalframenumber\hspace*{1ex}
      \end{beamercolorbox}%
    }%
  }%
}

% Title page
\setbeamertemplate{title page}{
  \begin{tikzpicture}[remember picture,overlay]
    \fill[lingnangrey!30!white]
      ([yshift=-1.15cm]current page.north west)
      rectangle
      ([yshift=-4.05cm]current page.north east);
  \end{tikzpicture}

  \vspace*{0.85cm}
  \begin{flushleft}
    {{\lingnanheadinglatinfont\bfseries\Large\usebeamercolor[fg]{title}\inserttitle}\par}
    \vskip0.45em
    \ifx\insertsubtitle\@empty
    \else
      {{\lingnanheadinglatinfont\usebeamercolor[fg]{subtitle}\insertsubtitle}\par}
    \fi
    \vskip2.9cm
    {\usebeamerfont{author}\insertauthor\par}
    \vskip0.55em
    {\usebeamerfont{institute}\insertinstitute\par}
  \end{flushleft}

  \vfill
}

% Section divider page
\setbeamertemplate{section page}{
  \begin{tikzpicture}[remember picture,overlay]
    \fill[white] (current page.south west) rectangle (current page.north east);
    \fill[ModernMist]
      ([xshift=0.0cm,yshift=-0.90cm]current page.north west)
      rectangle
      ([xshift=\paperwidth,yshift=-2.55cm]current page.north west);
    \fill[ModernRed]
      ([xshift=0.0cm,yshift=-0.90cm]current page.north west)
      rectangle
      ([xshift=0.34\paperwidth,yshift=-1.02cm]current page.north west);
    \fill[lingnangrey!45!white]
      ([xshift=0.34\paperwidth,yshift=-0.90cm]current page.north west)
      rectangle
      ([xshift=\paperwidth,yshift=-1.02cm]current page.north west);
    \fill[ModernRed]
      ([xshift=1.05cm,yshift=1.42cm]current page.south west)
      rectangle
      ([xshift=13.15cm,yshift=1.50cm]current page.south west);
    \node[anchor=west,inner sep=0pt]
      at ([xshift=1.05cm,yshift=-1.78cm]current page.north west)
      {\color{ModernRed}\sffamily\bfseries\fontsize{13}{15}\selectfont PART \thesection};
    \node[anchor=west,inner sep=0pt]
      at ([xshift=1.05cm,yshift=-3.22cm]current page.north west)
      {\color{lingnangrey!80!black}\sffamily\bfseries\fontsize{42}{42}\selectfont 0\thesection};
    \node[anchor=west,text width=0.78\paperwidth,align=left,inner sep=0pt]
      at ([xshift=3.05cm,yshift=-3.32cm]current page.north west)
      {\color{ModernInk}\sffamily\bfseries\fontsize{24}{29}\selectfont\insertsectionhead};
    \node[anchor=east,inner sep=0pt]
      at ([xshift=-1.05cm,yshift=-1.78cm]current page.north east)
      {\color{black!55}\sffamily\footnotesize \insertshortauthor};
    \node[anchor=west,text width=0.68\paperwidth,align=left,inner sep=0pt]
      at ([xshift=1.05cm,yshift=0.95cm]current page.south west)
      {\color{black!60}\sffamily\footnotesize \insertshorttitle};
    \node[anchor=west,inner sep=0pt]
      at ([xshift=1.05cm,yshift=0.48cm]current page.south west)
      {\color{black!62}\sffamily\scriptsize Greenwood, Hercowitz and Krusell (AER, 1997)};
    \node[anchor=east,inner sep=0pt]
      at ([xshift=-1.05cm,yshift=0.95cm]current page.south east)
      {\color{ModernRed}\sffamily\bfseries\scriptsize \insertshortdate};
  \end{tikzpicture}
}

% Show a table-of-contents slide before each section without adding a mini-frame dot.
\AtBeginSection[]{
  \begingroup
  \expandafter\let\csname beamer@writeslidentry\endcsname\relax
  \begin{frame}[plain,noframenumbering]{目录}
    \tableofcontents[currentsection,hideallsubsections]
  \end{frame}
  \endgroup
}

% Compact body spacing for classroom slides.
% This only changes list environments and displayed equations.
\newlength{\lingnanlistafterskip}
\setlength{\lingnanlistafterskip}{0.55em}
\newcommand{\listaftertext}{\vspace{\lingnanlistafterskip}}

\AtBeginEnvironment{itemize}{%
  \setlength{\itemsep}{2pt}%
  \setlength{\parsep}{0pt}%
  \setlength{\parskip}{0pt}%
  \setlength{\topsep}{2pt}%
  \setlength{\partopsep}{0pt}%
}

\AtBeginEnvironment{enumerate}{%
  \setlength{\itemsep}{2pt}%
  \setlength{\parsep}{0pt}%
  \setlength{\parskip}{0pt}%
  \setlength{\topsep}{2pt}%
  \setlength{\partopsep}{0pt}%
}

\g@addto@macro\normalsize{%
  \setlength{\abovedisplayskip}{4pt}%
  \setlength{\belowdisplayskip}{4pt}%
  \setlength{\abovedisplayshortskip}{2pt}%
  \setlength{\belowdisplayshortskip}{3pt}%
}

\mode<all>
